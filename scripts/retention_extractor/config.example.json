  "require_4k": false,
  "force_keyframes_at_cuts": true,
  "output_dir": "out/clips",
  "output_template": "{video_id}_clip{n:02d}_{start_ts}-{end_ts}.mp4",

  "republish_title_template": "Souvenir : {title}",
