/* ══════════════════════════════════════════════
   roadbook-ecosse.css
   Reproduction EXACTE du design page Écosse 2026
   Référence : road-trip-moto-ecosse-2026.html (styles inline)
   
   Ce fichier SURCHARGE les CSS de base (roadbook.css, roadbook-fusion.css,
   roadbook-blocs.css) pour obtenir le rendu identique à la page Écosse.
   Il doit être chargé EN DERNIER.
   ══════════════════════════════════════════════ */

/* ── VARIABLES RACINE (identiques Écosse) ──── */
:root {
    --orange: #e67e22;
    --orange-dark: #d35400;
    --vert: #2e7d32;
    --vert-dark: #1b5e20;
    --noir: #1a1a1a;
    --bg: #f7f7f5;
    --card: #fff;
    --border: #e5e5e5;
    --muted: #6f7782;
    --hero1: #163251;
    --hero2: #244b73;
}

/* ── POLICE : Arial comme la page Écosse ───── */
body {
    font-family: Arial, Helvetica, sans-serif;
    background: var(--bg);
    color: var(--noir);
    line-height: 1.7;
}

/* ── RESET général ─────────────────────────── */
* { margin: 0; padding: 0; box-sizing: border-box; }
a { text-decoration: none; color: inherit; }
img { max-width: 100%; display: block; }

/* ── TOPBAR ────────────────────────────────── */
.topbar {
    background: var(--orange);
    color: #fff;
    text-align: center;
    padding: 12px 16px;
    font-weight: 700;
}

/* ── WRAP ──────────────────────────────────── */
.wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 24px;
}

/* ── SECTION ───────────────────────────────── */
.section {
    padding: 32px 0;
}

/* ── CARD (24px radius, ombre bleue douce) ─── */
.card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 26px;
    box-shadow: 0 10px 28px rgba(18, 42, 74, .05);
}

/* ── SECTION KICKER ────────────────────────── */
.section-kicker {
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--orange);
    margin-bottom: 10px;
}

/* ── SECTION TITLE ─────────────────────────── */
.section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 10px;
    color: #163251;
}

.section-text {
    color: #425a74;
}


/* ══ BLOC RESSOURCES DU VOYAGE ═════════════════ */

.resources {
    background: linear-gradient(180deg, #fff9f2 0%, #fff 100%);
    border-color: #ffd0a6;
    margin-top: -34px;
    position: relative;
    z-index: 2;
}

.resources-grid {
    display: grid;
    grid-template-columns: 1.45fr .9fr;
    gap: 20px;
    align-items: stretch;
}

.resources-left {
    display: grid;
    gap: 20px;
}

.resource-panel {
    background: #fff;
    border: 1px solid #f1d4ba;
    border-radius: 20px;
    padding: 20px;
}

.resource-panel h3 {
    font-size: 1.15rem;
    color: #163251;
    margin-bottom: 8px;
}

.resource-panel p {
    color: #425a74;
}

/* ── BOUTONS (pill shape comme Écosse) ─────── */
.btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 16px;
}

.btn {
    display: inline-block;
    padding: 14px 20px;
    border-radius: 999px;
    font-weight: 700;
    font-size: .88rem;
    cursor: pointer;
    transition: all .2s;
}

.btn-primary {
    background: var(--orange);
    color: #fff;
}

.btn-primary:hover {
    background: var(--orange-dark);
}

.btn-dark {
    background: #243c5a;
    color: #fff;
}

.btn-dark:hover {
    background: #1a2d42;
}

.btn-light {
    background: #edf5ff;
    border: 1px solid #cfe0f5;
    color: #163251;
}

.btn-light:hover {
    background: #dde9f8;
}

/* ── NOTE ──────────────────────────────────── */
.note {
    font-size: .9rem;
    color: #5f6d7c;
    margin-top: 14px;
}

/* ── QR BOX ────────────────────────────────── */
.qr-box {
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
    background: #fff;
    border: 2px dashed var(--orange);
    border-radius: 22px;
    padding: 20px;
    min-height: 100%;
}

.qr-box img {
    max-width: 190px;
    margin: 10px auto 0;
    border-radius: 12px;
    background: #fff;
    padding: 10px;
}

/* ── INTRO COPY (Immersion) ────────────────── */
.intro-copy p {
    color: #425a74;
    font-size: 1rem;
    line-height: 1.8;
}


/* ══ BLOC JOURNAL DE BORD ══════════════════════ */

.journal-preview {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
}

.journal-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.journal-card img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    width: 100%;
    border-radius: 20px 20px 0 0;
}

.journal-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.journal-meta {
    font-size: .75rem;
    font-weight: 700;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 8px;
    text-align: center;
}

.journal-body h3 {
    font-size: 1.05rem;
    color: #163251;
    margin-bottom: 6px;
}

.journal-body p {
    font-size: .92rem;
    color: #536579;
    line-height: 1.6;
}

.journal-actions {
    margin-top: auto;
    padding-top: 14px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}


/* ══ BANDEAU SUIVRE L'AVENTURE ════════════════ */
/* Fond CRÈME comme Écosse (PAS orange) */

.follow-box {
    margin-top: 26px;
    background: #fff8f2;
    border: 1px solid #f1d4ba;
    border-radius: 22px;
    padding: 22px;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
}

.follow-box h3 {
    font-size: 1.35rem;
    color: #163251;
    margin-bottom: 6px;
}

.follow-box p {
    color: #536579;
    max-width: 740px;
}

/* Surcharge du .jnl-cta si utilisé à la place de .follow-box */
.jnl-cta {
    background: #fff8f2;
    border: 1px solid #f1d4ba;
    border-radius: 22px;
}

.jnl-cta-text h3 {
    color: #163251;
}

.jnl-cta-text p {
    color: #536579;
}

.jnl-cta .btn.btn-white {
    background: var(--orange);
    color: #fff;
}


/* ══ COMPATIBILITÉ SHORT-CARD (injection Python) ══
   auto_publish_roadtrip.py injecte des .short-card
   dans .journal-preview — ce bloc les re-style pour
   qu'elles aient le même rendu que les .journal-card
   ══════════════════════════════════════════════════ */

.journal-preview .short-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    padding: 0;
    margin: 0;
    box-shadow: none;
    display: flex;
    flex-direction: column;
}

.journal-preview .short-thumb {
    border-radius: 0;
    margin: 0;
    position: relative;
}

.journal-preview .short-thumb img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    width: 100%;
    border-radius: 20px 20px 0 0;
}

.journal-preview .short-badge {
    display: block;
    font-size: .75rem;
    font-weight: 700;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 8px;
    text-align: center;
    position: static;
    background: none;
    padding: 0;
}

.journal-preview .short-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.journal-preview .short-body h3 {
    font-size: 1.05rem;
    color: #163251;
    margin-bottom: 6px;
}

.journal-preview .short-body p {
    font-size: .92rem;
    color: #536579;
    line-height: 1.6;
}

.journal-preview .short-body .btn {
    display: inline-block;
    padding: 14px 20px;
    border-radius: 999px;
    font-weight: 700;
    background: #243c5a;
    color: #fff;
    font-size: .88rem;
    margin-top: auto;
    align-self: flex-start;
}


/* ══ RESPONSIVE ═══════════════════════════════ */

@media (max-width: 900px) {
    .resources-grid,
    .journal-preview {
        grid-template-columns: 1fr;
    }

    .resources {
        margin-top: 20px;
    }

    .hero {
        min-height: auto;
    }

    .hero-inner {
        padding-top: 28px;
        padding-bottom: 56px;
    }

    .follow-box {
        flex-direction: column;
        text-align: center;
    }
}
