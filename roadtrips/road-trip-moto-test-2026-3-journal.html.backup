<style>
:root {
    --orange: #e67e22;
    --orange-dark: #d35400;
    --bleu: #163251;
    --bleu2: #244b73;
    --bg: #f7f7f5;
    --alt: #f0ede8;
    --card: #fff;
    --border: #e5e5e5;
    --noir: #1a1a1a;
    --muted: #777;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--noir); line-height: 1.7; }
a { color: inherit; text-decoration: none; }

/* ─── HEADER ─── */
.header {
    background: linear-gradient(135deg, var(--bleu), var(--bleu2));
    color: #fff;
    padding: 56px 24px;
    text-align: center;
}
.header h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 800;
    margin: 0 0 .3rem;
}
.header-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: rgba(255,255,255,.6);
    margin: 0 0 .8rem;
}
.header p {
    max-width: 700px;
    margin: 0 auto 1.2rem;
    color: #e0e5ed;
    font-size: .95rem;
    line-height: 1.7;
}
.btn {
    display: inline-flex;
    align-items: center;
    padding: .7rem 1.4rem;
    border-radius: 8px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .88rem;
    background: var(--orange);
    color: #fff;
    transition: background .2s;
}
.btn:hover { background: var(--orange-dark); }

/* ─── WRAP ─── */
.wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 20px 3rem;
}

/* ─── KICKER SECTION ─── */
.section-kicker {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: .8rem;
}
.section-count {
    font-size: .88rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
}

/* ─── JOURNAL CARD HORIZONTAL ─── */
.journal-card {
    display: grid;
    grid-template-columns: 340px 1fr;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 3px 10px rgba(0,0,0,.04);
    margin-bottom: 1.2rem;
    transition: box-shadow .2s, transform .15s;
}
.journal-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
    transform: translateY(-2px);
}

/* Thumbnail gauche */
.journal-thumb {
    position: relative;
    background: var(--alt) center/cover no-repeat;
    min-height: 180px;
}
.journal-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.journal-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,.05), rgba(0,0,0,.2));
    pointer-events: none;
}
.journal-badge {
    position: absolute;
    left: 12px;
    top: 12px;
    z-index: 1;
    background: var(--orange);
    color: #fff;
    padding: .3rem .7rem;
    border-radius: 999px;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .04em;
    text-transform: uppercase;
}

/* Corps droite */
.journal-body {
    padding: 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.journal-body h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 .4rem;
    color: var(--noir);
}
.journal-body p {
    margin: 0 0 .8rem;
    color: var(--muted);
    font-size: .9rem;
    line-height: 1.6;
}
.journal-body .btn-sm {
    display: inline-flex;
    align-self: flex-start;
    padding: .5rem 1rem;
    border-radius: 6px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .78rem;
    background: var(--noir);
    color: #fff;
    transition: background .2s;
}
.journal-body .btn-sm:hover { background: #333; }

/* ─── ÉTAT VIDE ─── */
.journal-empty {
    background: var(--card);
    border: 1px dashed var(--border);
    border-radius: 18px;
    padding: 2.5rem;
    text-align: center;
    color: var(--muted);
}
.journal-empty h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    margin-bottom: .5rem;
    color: var(--noir);
}

/* ─── RESPONSIVE ─── */
@media (max-width: 640px) {
    .journal-card {
        grid-template-columns: 1fr;
    }
    .journal-thumb {
        min-height: 200px;
    }
}

footer{background:#1a1a1a;color:rgba(255,255,255,.65);padding:2.8rem 6%;margin-top:4rem;text-align:center}
.f-logo{font-family:"Montserrat",sans-serif;font-size:1.6rem;font-weight:800;color:#fff}
.f-logo em{font-style:normal;color:var(--orange,#e67e22)}
.f-nav{list-style:none;display:flex;flex-wrap:wrap;justify-content:center;gap:.5rem 1.5rem;margin:.8rem 0}
.f-nav a{font-size:.8rem;color:rgba(255,255,255,.55);text-decoration:none}
.f-nav a:hover{color:var(--orange,#e67e22)}
.f-legal{font-size:.76rem;color:rgba(255,255,255,.3);margin-top:1.1rem;line-height:1.7}
</style>
</head>
