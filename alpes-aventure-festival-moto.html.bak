    <!-- Schema FAQPage -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Quelle est la meilleure période pour un road trip moto dans les Alpes ?",
          "acceptedAnswer": { "@type": "Answer", "text": "La meilleure période s'étend de juin à septembre, quand tous les cols sont ouverts. En mai, certains cols comme l'Iseran ou le Galibier peuvent encore être fermés. Septembre offre des paysages magnifiques avec les couleurs d'automne et moins de monde sur les routes." }
        },
        {
          "@type": "Question",
          "name": "Quelle moto pour traverser les Alpes ?",
          "acceptedAnswer": { "@type": "Answer", "text": "J'ai fait ce road trip sur Benelli TRK 502, un trail routier parfait pour les cols. Une moto entre 500cc et 1200cc est idéale, avec un bon confort pour les longues étapes. L'important est d'avoir des pneus en bon état et une protection contre le froid en altitude." }
        },
        {
          "@type": "Question",
          "name": "Peut-on bivouaquer dans les Alpes ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Oui, mais c'est réglementé. En dessous de 2000m, préférez les campings (20-30€/nuit). En altitude, le bivouac est toléré mais interdit dans les parcs nationaux. J'ai bivouaqué au col de Tende (1870m) et au col de la Bonnette, mais il faut être bien équipé car les nuits sont fraîches même en été." }
        }
      ]
    }
    </script>

