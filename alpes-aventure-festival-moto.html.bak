        .catch(() => document.getElementById('lcdmh-nav-container').innerHTML = '<nav style="background:#fff;padding:1rem;"><a href="/" style="color:#e67e22;">LCDMH</a></nav>');
</script>

<!-- ======================================== -->
<!-- MODULE ROAD TRIP (ressources + QR)      -->
