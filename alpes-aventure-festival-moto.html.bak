<!-- ======================================== -->
<!-- GUIDE PRATIQUE                           -->
<!-- ======================================== -->
<section class="section" id="guide-pratique">
    <div class="sec-head">
        <h2>Guide Pratique : <em>Traverser les Alpes à Moto</em></h2>
        <div class="bar"></div>
        <p>Conseils basés sur mon expérience réelle</p>
    </div>

    <div class="guide-grid">

        <div class="guide-card">
            <div class="guide-icon">🗓️</div>
            <h3>Quand partir ?</h3>
            <ul>
                <li><strong>Juin à septembre</strong> : tous les cols ouverts</li>
                <li><strong>Mai</strong> : risque de cols fermés (Iseran, Galibier)</li>
                <li><strong>Septembre</strong> : idéal (moins de monde, couleurs d'automne)</li>
                <li>Évitez juillet-août si possible (affluence)</li>
                <li>Vérifiez l'ouverture des cols avant de partir</li>
            </ul>
        </div>

        <div class="guide-card">
            <div class="guide-icon">🏍️</div>
            <h3>Quelle moto ?</h3>
            <ul>
                <li><strong>Benelli TRK 502</strong> : parfaite pour débuter</li>
                <li>Trail routier 500-1200cc idéal</li>
                <li>Pneus en bon état impératif</li>
                <li>Protection contre le froid en altitude</li>
                <li>GPS ou téléphone avec cartes offline</li>
            </ul>
        </div>

        <div class="guide-card">
            <div class="guide-icon">🏕️</div>
            <h3>Bivouac & Hébergement</h3>
            <ul>
                <li>Campings : 20-30€/nuit (douches chaudes)</li>
                <li>Bivouac toléré en altitude (>2000m)</li>
                <li>Interdit dans les parcs nationaux</li>
                <li>Prévoir duvet chaud (nuits fraîches)</li>
                <li>Mon camping préféré : Barcelonnette</li>
            </ul>
        </div>

        <div class="guide-card">
            <div class="guide-icon">🗺️</div>
            <h3>Les cols à ne pas rater</h3>
            <ul>
                <li><strong>Col de l'Iseran</strong> (2770m) : le plus haut</li>
                <li><strong>Col du Galibier</strong> (2645m) : mythique</li>
                <li><strong>Col de la Bonnette</strong> (2860m) : plus haute route d'Europe</li>
                <li><strong>Col de Valcavera</strong> (2416m) : secret, paysages dolomitiques</li>
                <li><strong>Lacets de Montvernier</strong> : 17 lacets spectaculaires</li>
            </ul>
        </div>

        <div class="guide-card">
            <div class="guide-icon">💰</div>
            <h3>Budget estimé</h3>
            <ul>
                <li>Essence : 150-200€ (1800 km)</li>
                <li>Hébergement : 20-30€/nuit en camping</li>
                <li>Restauration : 25-40€/jour</li>
                <li>Péages : peu ou pas (cols gratuits)</li>
                <li>Total : 500-700€ pour 8 jours</li>
            </ul>
        </div>

        <div class="guide-card">
            <div class="guide-icon">⚠️</div>
            <h3>Conseils de survie</h3>
            <ul>
                <li>Météo changeante : prévoir vêtements chauds</li>
                <li>Attention aux gravillons dans les virages</li>
                <li>Anticiper la fatigue sur longs trajets</li>
                <li>Vérifier la pression des pneus chaque jour</li>
                <li>Prendre son temps, profiter des arrêts</li>
            </ul>
        </div>

    </div>
</section>

