    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        :root{
            --orange:#e67e22;--orange-dark:#d35400;
            --noir:#1a1a1a;--bg:#f7f7f5;--alt:#f0ede8;
            --card:#fff;--border:#e5e5e5;--muted:#777;
            --alpes:#1b4332;
        }
        html{scroll-behavior:smooth}
        body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--noir);line-height:1.7}
        h1,h2,h3,h4{font-family:'Montserrat',sans-serif}
        a{color:inherit;text-decoration:none}
        .section{padding:72px 6%}
        .section-alt{background:var(--alt)}
        .sec-head{text-align:center;margin-bottom:2.8rem}
        .sec-head h2{font-size:clamp(1.5rem,3vw,2.2rem);font-weight:800;margin-bottom:.4rem}
        .sec-head h2 em{font-style:normal;color:var(--orange)}
        .sec-head p{color:var(--muted);max-width:640px;margin:.6rem auto 0;font-size:.95rem}
        .bar{width:52px;height:4px;background:var(--orange);border-radius:2px;margin:.8rem auto 0}
        .btn{font-family:'Montserrat',sans-serif;font-size:.88rem;font-weight:700;padding:.8rem 1.9rem;border-radius:8px;border:none;cursor:pointer;transition:all .2s;display:inline-block}
        .btn-orange{background:var(--orange);color:#fff}.btn-orange:hover{background:var(--orange-dark)}
        .btn-outline{background:transparent;color:var(--orange);border:2px solid var(--orange)}.btn-outline:hover{background:var(--orange);color:#fff}

        /* NAV */
        nav{background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.07);padding:0 4%;height:70px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
        .logo{font-size:1.6rem;font-weight:800;color:var(--noir)}.logo span{color:var(--orange)}
        .nav-links{display:flex;gap:1rem;list-style:none}
        .nav-links a{font-size:.78rem;font-weight:600;color:var(--muted);text-transform:uppercase}
        .nav-links a:hover,.nav-links a.active{color:var(--orange)}
        .has-drop{position:relative}
        .has-drop>a::after{content:'▾';font-size:.6rem;margin-left:.2rem}
        .dropdown{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid var(--border);border-radius:10px;min-width:200px;padding:.5rem 0;z-index:999}
        .has-drop:hover .dropdown{display:block}
        .dropdown a{display:block;padding:.5rem 1rem;font-size:.8rem}
        .dropdown a:hover{background:#fff8f2;color:var(--orange)}
        .menu-toggle{display:none}
        @media(max-width:900px){
            .nav-links{display:none;flex-direction:column;position:absolute;top:70px;left:0;width:100%;background:#fff;padding:1rem 0;box-shadow:0 10px 20px rgba(0,0,0,.1);z-index:1000}
            .nav-links.active{display:flex}
            .nav-links li{width:100%;text-align:center}
            .nav-links a{display:block;padding:1rem!important}
            .dropdown{position:static;width:100%;box-shadow:none;border:none}
            .menu-toggle{display:block;font-size:2rem;cursor:pointer;background:none;border:none}
        }

        /* HERO */
        .hero-alpes{
            background:linear-gradient(160deg,#0d2818 0%,#1b4332 40%,#2d6a4f 75%);
            color:white;padding:5rem 6% 4rem;text-align:center;
        }
        .breadcrumb{font-size:.78rem;color:rgba(255,255,255,.4);margin-bottom:1.2rem}
        .breadcrumb a{color:rgba(255,255,255,.5)}.breadcrumb a:hover{color:var(--orange)}
        .hero-badge{display:inline-block;background:var(--orange);color:#fff;font-size:.7rem;font-weight:800;padding:.4rem 1.2rem;border-radius:50px;margin-bottom:1.2rem}
        .hero-alpes h1{font-size:clamp(2rem,5vw,3.5rem);font-weight:900;margin-bottom:1.2rem}
        .hero-alpes h1 em{font-style:normal;color:#b7e4c7}
        .hero-subtitle{font-size:clamp(.9rem,2vw,1.1rem);color:rgba(255,255,255,.75);max-width:700px;margin:0 auto 2rem}
        .hero-meta{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;color:rgba(255,255,255,.5);font-size:.82rem;margin-bottom:2rem}
        .hero-kpis{display:flex;justify-content:center;gap:1.5rem 3rem;flex-wrap:wrap;border-top:1px solid rgba(255,255,255,.1);padding-top:2rem}
        .kpi{text-align:center}
        .kpi strong{display:block;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:#b7e4c7;line-height:1}
        .kpi span{font-size:.72rem;text-transform:uppercase;color:rgba(255,255,255,.45)}

        /* ROUTE COLS */
        .route-cols{display:flex;align-items:center;justify-content:center;gap:.3rem;flex-wrap:wrap;max-width:1000px;margin:0 auto;padding:1.5rem 0}
        .col-stop{text-align:center}
        .col-stop .alt{font-size:.65rem;font-weight:700;color:var(--orange)}
        .col-stop .name{font-size:.8rem;font-weight:700}
        .route-arrow{color:var(--orange);font-size:1rem}

        /* INTRO */
        .intro-block{max-width:820px;margin:0 auto;font-size:1.05rem;line-height:1.9;color:#333}
        .intro-block .citation{border-left:4px solid var(--orange);padding:1rem 1.5rem;background:#fff;border-radius:0 12px;font-style:italic;color:#555;margin:1.8rem 0}

        /* STATS BAR */
        .stats-bar{background:var(--noir);color:#fff;padding:2rem 6%;display:flex;justify-content:center;gap:2rem 4rem;flex-wrap:wrap}
        .stat-item{text-align:center}
        .stat-item strong{display:block;font-size:2rem;font-weight:900;color:var(--orange)}
        .stat-item span{font-size:.75rem;text-transform:uppercase;color:rgba(255,255,255,.5)}

        /* TIMELINE */
        .timeline{max-width:900px;margin:0 auto;position:relative}
        .timeline::before{content:'';position:absolute;left:28px;top:0;bottom:0;width:3px;background:linear-gradient(180deg,var(--orange),var(--alpes))}
        @media(max-width:600px){.timeline::before{left:20px}}
        .tl-item{display:flex;gap:2rem;margin-bottom:2.5rem;align-items:flex-start}
        .tl-dot{width:58px;height:58px;border-radius:50%;background:var(--orange);border:4px solid #fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.75rem;font-weight:900;color:#fff;z-index:1}
        .tl-dot.ep{background:var(--alpes)}
        .tl-dot.milestone{background:#e74c3c}
        .tl-content{flex:1;background:#fff;border-radius:16px;padding:1.4rem 1.6rem;border:1px solid var(--border)}
        .tl-ep{font-size:.72rem;font-weight:700;text-transform:uppercase;color:var(--orange);margin-bottom:.3rem}
        .tl-content h3{font-size:1.1rem;margin-bottom:.5rem}
        .tl-content p{font-size:.92rem;color:#555}
        .tl-tag{display:inline-block;background:var(--alt);color:var(--muted);font-size:.72rem;padding:.2rem .7rem;border-radius:50px;margin:.3rem}
        .tl-tag.orange{background:#fff0e6;color:var(--orange)}
        .tl-tag.red{background:#fdf0f0;color:#e74c3c}
        .tl-video-link{display:inline-flex;align-items:center;gap:.4rem;margin-top:.8rem;font-weight:700;color:var(--orange)}

        /* EPISODE GRID */
        .ep-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.2rem;max-width:1100px;margin:0 auto}
        .ep-card{background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--border);transition:transform .2s}
        .ep-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
        .ep-thumb{position:relative;aspect-ratio:16/9;overflow:hidden}
        .ep-thumb img{width:100%;height:100%;object-fit:cover}
        .ep-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:48px;height:48px;background:var(--orange);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:.9}
        .ep-play::after{content:'▶';color:#fff;font-size:1rem}
        .ep-num{position:absolute;top:10px;left:10px;background:var(--orange);color:#fff;font-size:.7rem;font-weight:800;padding:.2rem .7rem;border-radius:50px}
        .ep-body{padding:1rem}
        .ep-body h3{font-size:.95rem;margin-bottom:.4rem}
        .ep-body p{font-size:.82rem;color:var(--muted)}

        /* GUIDE GRID */
        .guide-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.4rem;max-width:1000px;margin:0 auto}
        .guide-card{background:#fff;border-radius:16px;padding:1.6rem;border:1px solid var(--border)}
        .guide-icon{font-size:2rem;margin-bottom:.8rem}
        .guide-card h3{font-size:1rem;margin-bottom:.8rem}
        .guide-card ul{list-style:none}
        .guide-card ul li{padding:.3rem 0;border-bottom:1px solid #f5f5f5;display:flex;gap:.5rem}
        .guide-card ul li:last-child{border:none}
        .guide-card ul li::before{content:'→';color:var(--orange);font-weight:700}

        /* FAQ */
        .faq-item{background:#fff;border-radius:14px;border:1px solid var(--border);margin-bottom:1rem;overflow:hidden;max-width:800px;margin-left:auto;margin-right:auto}
        .faq-q{display:flex;justify-content:space-between;align-items:center;padding:1.2rem 1.5rem;cursor:pointer;font-weight:600}
        .faq-q:hover{background:#fff8f2}
        .faq-q::after{content:'＋';color:var(--orange)}
        .faq-item.open .faq-q::after{content:'－'}
        .faq-a{display:none;padding:0 1.5rem 1.2rem;color:#555}
        .faq-item.open .faq-a{display:block}

        /* INTERNAL LINKS */
        .link-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.9rem;max-width:900px;margin:0 auto}
        .link-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:1rem;text-align:center;transition:box-shadow .2s}
        .link-card:hover{box-shadow:0 4px 14px rgba(0,0,0,.08);color:var(--orange)}

        /* FOOTER */
        footer{background:var(--noir);color:rgba(255,255,255,.6);padding:2.8rem 6%;text-align:center}
        .footer-logo{font-size:1.6rem;font-weight:800;color:#fff}
        .footer-logo em{font-style:normal;color:var(--orange)}
        .footer-links{display:flex;gap:1.5rem;justify-content:center;flex-wrap:wrap;margin:1.2rem 0;list-style:none}
        .footer-links a{font-size:.8rem;color:rgba(255,255,255,.5);transition:color .2s}
        .footer-links a:hover{color:var(--orange)}
    </style>
</head>
<body>

