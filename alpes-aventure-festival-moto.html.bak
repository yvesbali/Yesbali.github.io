<div id="lcdmh-roadtrip-module"></div>
<script src="roadtrip-module.html"></script>

<!-- ======================================== -->
<!-- HERO                                     -->
<!-- ======================================== -->
<div class="hero-alpes">
    <div class="breadcrumb">
        <a href="index.html">Accueil</a><span> › </span>
        <a href="roadtrips.html">Road Trips</a><span> › </span>
        Alpes 2022
    </div>
    <div class="hero-badge">🏔️ Road Trip Moto — Récit Complet</div>
    <h1>Les Alpes à Moto :<br><em>Annecy → Nice</em> par les plus beaux cols</h1>
    <p class="hero-subtitle">8 épisodes, 1800 km, des cols mythiques (Galibier, Iseran, Bonette), une chute au col de Tende, et des nuits en bivouac à 2000m d'altitude.</p>
    <div class="hero-meta">
        <span>✍️ Yves – LCDMH</span>
        <span>📅 Septembre 2022</span>
        <span>🏍️ Benelli TRK 502</span>
        <span>🎬 8 épisodes</span>
        <span>👁️ +30 000 vues</span>
    </div>
    <div class="hero-kpis">
        <div class="kpi"><strong>1 800</strong><span>km parcourus</span></div>
        <div class="kpi"><strong>15+</strong><span>cols franchis</span></div>
        <div class="kpi"><strong>2 860m</strong><span>Col de la Bonnette</span></div>
        <div class="kpi"><strong>⛰️</strong><span>Bivouac en altitude</span></div>
    </div>
</div>

<!-- ======================================== -->
<!-- ROUTE VISUELLE                            -->
<!-- ======================================== -->
<div style="background:#fff;padding:1.5rem 4%;border-bottom:1px solid var(--border)">
    <div class="route-cols">
        <div class="col-stop"><span class="alt">430m</span><span class="name">Annecy</span></div>
        <div class="route-arrow">→</div>
        <div class="col-stop"><span class="alt">2083m</span><span class="name">Mont-Cenis</span></div>
        <div class="route-arrow">→</div>
        <div class="col-stop"><span class="alt">2645m</span><span class="name">Galibier</span></div>
        <div class="route-arrow">→</div>
        <div class="col-stop"><span class="alt">2860m</span><span class="name">Bonnette</span></div>
        <div class="route-arrow">→</div>
        <div class="col-stop"><span class="alt">2351m</span><span class="name">Lombarde</span></div>
        <div class="route-arrow">→</div>
        <div class="col-stop"><span class="alt">2416m</span><span class="name">Valcavera</span></div>
        <div class="route-arrow">→</div>
        <div class="col-stop"><span class="alt">1870m</span><span class="name">Tende</span></div>
