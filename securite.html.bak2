<!-- Hero -->
<section class="hero">
    <div class="hero-image"></div>
    <div class="hero-content">
        <h1>SÉCURITÉ <span>À MOTO</span></h1>
        <p>Conseils, formations et équipements pour rouler en toute sécurité.</p>
    </div>
</section>

<!-- Introduction -->
<div class="container">
    <div class="intro-box">
        <p style="font-size: 1.1rem; color: #666;">
            Après plus de 72 000 km sur les routes d'Europe, j'ai appris que la sécurité ne se limite pas à l'équipement.
            C'est une combinaison de bonnes pratiques, d'anticipation, de technique de pilotage et de visibilité.
            J'ai eu la chance de participer à des formations avec la gendarmerie et des instructeurs professionnels.
            Voici ce que j'ai appris et que je mets en pratique chaque jour.
        </p>
    </div>

    <!-- Section TRAJECTOIRES DE SÉCURITÉ -->
    <div class="section-title">
        <h2>TRAJECTOIRES DE SÉCURITÉ</h2>
        <div class="bar"></div>
    </div>
    <div class="tips-grid">
        <!-- Virage -->
        <div class="tip-card">
            <div class="tip-header">
                <h3>Bien prendre un virage</h3>
                <div class="badge">Technique</div>
            </div>
            <div class="tip-content">
                <ul>
                    <li>✅ Ralentissez avant le virage, pas dans le virage</li>
                    <li>✅ Regardez le plus loin possible (là où vous voulez aller)</li>
                    <li>✅ Positionnez-vous à l'extérieur du virage à l'entrée</li>
                    <li>✅ Accélérez progressivement en sortie</li>
                    <li>⚠️ Évitez de freiner en courbe</li>
                </ul>
            </div>
            <div class="tip-footer">
                <a href="https://youtu.be/KGfovxM_Q7w" class="btn" target="_blank" rel="noopener">Voir la formation</a>
            </div>
        </div>

        <!-- Freinage d'urgence (texte uniquement) -->
        <div class="tip-card">
            <div class="tip-header">
                <h3>Freinage d'urgence</h3>
                <div class="badge">Survie</div>
            </div>
            <div class="tip-content">
                <ul>
                    <li>✅ Serrez fermement le frein avant (80% de la puissance)</li>
                    <li>✅ Frein arrière en complément (20%)</li>
                    <li>✅ Gardez la moto droite</li>
                    <li>✅ Relâchez progressivement en fin de freinage</li>
                    <li>⚠️ Entraînez-vous sur parking sécurisé</li>
                </ul>
            </div>
            <div class="tip-footer">
                <span style="color: #666; font-style: italic;">Entraînement personnel recommandé</span>
            </div>
        </div>

        <!-- Regard et anticipation -->
        <div class="tip-card">
            <div class="tip-header">
                <h3>Regard & anticipation</h3>
                <div class="badge">Clé</div>
            </div>
            <div class="tip-content">
                <ul>
                    <li>✅ Regardez toujours là où vous voulez aller</li>
                    <li>✅ Anticipez les trajectoires des autres véhicules</li>
                    <li>✅ Scannez les intersections, les sorties de garage</li>
                    <li>✅ Gardez une distance de sécurité suffisante</li>
                </ul>
            </div>
            <div class="tip-footer">
                <a href="https://youtu.be/mqrxymLts_0" class="btn" target="_blank" rel="noopener">Voir la vidéo</a>
            </div>
        </div>
    </div>

    <!-- Section ÉQUIPEMENT DE SÉCURITÉ -->
    <div class="section-title">
        <h2>ÉQUIPEMENT DE SÉCURITÉ</h2>
        <div class="bar"></div>
    </div>
    <div class="tips-grid">
        <!-- Casque -->
        <div class="tip-card">
            <div class="tip-header">
                <h3>Casque</h3>
                <div class="badge">Indispensable</div>
            </div>
            <div class="tip-content">
                <ul>
                    <li>✅ Homologué (ECE 22.06)</li>
                    <li>✅ Bien ajusté, pas trop lâche</li>
                    <li>✅ Visière claire pour la nuit</li>
                    <li>✅ Remplacez-le après un choc</li>
                </ul>
            </div>
            <div class="tip-footer">
                <a href="tests-motos.html" class="btn">Voir les tests</a>
            </div>
        </div>

        <!-- Gants (texte uniquement) -->
        <div class="tip-card">
            <div class="tip-header">
                <h3>Gants</h3>
                <div class="badge">Protection</div>
            </div>
            <div class="tip-content">
                <ul>
                    <li>✅ Avec coques de protection</li>
                    <li>✅ Adaptés à la saison</li>
                    <li>✅ Bonne préhension des commandes</li>
                    <li>✅ Renforcés au niveau des paumes</li>
                </ul>
            </div>
            <div class="tip-footer">
                <span style="color: #666; font-style: italic;">Équipement de base essentiel</span>
            </div>
        </div>

        <!-- Gilet airbag (texte uniquement) -->
        <div class="tip-card">
            <div class="tip-header">
                <h3>Gilet airbag</h3>
                <div class="badge">Protection active</div>
            </div>
            <div class="tip-content">
                <ul>
                    <li>✅ Protection cervicale et dorsale</li>
                    <li>✅ Déclenchement en cas de chute</li>
                    <li>✅ De plus en plus abordable</li>
                    <li>✅ Recommandé pour la route</li>
                </ul>
            </div>
            <div class="tip-footer">
                <span style="color: #666; font-style: italic;">Investissement sécurité</span>
            </div>
        </div>
    </div>

    <!-- Vidéos formation avec MINIATURES -->
    <div class="section-title">
        <h2>MES VIDÉOS FORMATION</h2>
        <div class="bar"></div>
    </div>
    <div class="video-grid">
        <!-- Trajectoires avec Gendarmerie -->
        <div class="video-card" onclick="window.open('https://youtu.be/KGfovxM_Q7w', '_blank')">
            <div class="video-thumb">
                <img src="https://img.youtube.com/vi/KGfovxM_Q7w/hqdefault.jpg" alt="Formation trajectoires de sécurité">
            </div>
            <div class="video-info">
                <h4>Formation trajectoires de sécurité</h4>
                <p>Une journée d'entraînement avec un motard gendarme pour apprendre les bonnes trajectoires.</p>
            </div>
