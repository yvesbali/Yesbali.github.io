<!-- ÉTAPES DU VOYAGE -->
<section class="section section-alt">
    <div class="sec-head">
        <h2>Les <em>étapes</em> du voyage</h2>
        <div class="bar"></div>
        <p>D'Annecy aux Highlands écossais en passant par l'Irlande — un road trip bivouac en conditions réelles</p>
    </div>
    <div class="etapes">
        <div class="etape">
            <div class="etape-icon">🏔️</div>
