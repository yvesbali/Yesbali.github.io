    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --orange: #e67e22;
            --orange-dark: #d35400;
            --noir: #1a1a2e;
            --alt: #f8f9fa;
            --border: #e8e8e8;
        }
        body { font-family: 'Inter', sans-serif; color: var(--noir); background: #fff; }

        /* ── NAV ── */
        nav {
            position: sticky; top: 0; z-index: 100;
            background: var(--noir);
            display: flex; align-items: center; justify-content: space-between;
            padding: .9rem 6%;
        }
        .nav-logo { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 1.4rem; color: #fff; text-decoration: none; }
        .nav-logo em { color: var(--orange); font-style: normal; }
        .nav-links { display: flex; gap: 1.5rem; list-style: none; }
        .nav-links a { color: rgba(255,255,255,.75); text-decoration: none; font-size: .88rem; font-weight: 500; transition: color .2s; }
        .nav-links a:hover { color: var(--orange); }

        /* ── HERO ── */
        .hero-trip {
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            color: #fff;
            padding: 80px 6% 60px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero-trip::before {
            content: "";
            position: absolute; inset: 0;
            background: url('images/og-lcdmh.jpg') center/cover no-repeat;
            opacity: .15;
        }
        .hero-trip > * { position: relative; }
        .hero-badge {
            display: inline-block;
            background: var(--orange);
            color: #fff;
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            padding: .35rem .9rem;
            border-radius: 50px;
            margin-bottom: 1.2rem;
        }
        .hero-trip h1 {
            font-family: 'Montserrat', sans-serif;
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 800;
            line-height: 1.15;
            margin-bottom: 1rem;
        }
        .hero-trip h1 em { color: var(--orange); font-style: normal; }
        .hero-trip p {
            font-size: 1.1rem;
            color: rgba(255,255,255,.8);
            max-width: 600px;
            margin: 0 auto 2rem;
            line-height: 1.6;
        }
        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 2.5rem;
            flex-wrap: wrap;
            margin-top: 2rem;
        }
        .hero-stat { text-align: center; }
        .hero-stat strong { display: block; font-size: 1.8rem; font-weight: 800; color: var(--orange); }
        .hero-stat span { font-size: .8rem; color: rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .08em; }

        /* ── SECTION ── */
        .section { padding: 64px 6%; }
        .section-alt { background: var(--alt); }
        .sec-head { text-align: center; margin-bottom: 2.5rem; }
        .sec-head h2 { font-family: 'Montserrat', sans-serif; font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 800; margin-bottom: .5rem; }
        .sec-head h2 em { color: var(--orange); font-style: normal; }
        .bar { width: 48px; height: 4px; background: var(--orange); margin: .75rem auto; border-radius: 2px; }
        .sec-head p { color: #666; font-size: 1rem; max-width: 580px; margin: 0 auto; line-height: 1.6; }

        /* ── ÉTAPES ── */
        .etapes {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.5rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .etape {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem 1.2rem;
            text-align: center;
            transition: transform .2s, box-shadow .2s;
        }
        .etape:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.08); }
        .etape-icon { font-size: 2rem; margin-bottom: .75rem; }
        .etape h3 { font-size: .95rem; font-weight: 700; margin-bottom: .4rem; }
        .etape p { font-size: .8rem; color: #777; line-height: 1.5; }

        /* ── COMING SOON ── */
        .coming-soon {
            text-align: center;
            padding: 3rem 1rem;
            background: linear-gradient(135deg, #f8f9fa, #fff);
            border: 2px dashed var(--border);
            border-radius: 16px;
            max-width: 600px;
            margin: 0 auto;
        }
        .coming-soon .icon { font-size: 3rem; margin-bottom: 1rem; }
        .coming-soon h3 { font-family: 'Montserrat', sans-serif; font-size: 1.3rem; font-weight: 700; margin-bottom: .75rem; }
        .coming-soon p { color: #666; font-size: .9rem; line-height: 1.6; }
        .countdown {
            display: inline-block;
            background: var(--orange);
            color: #fff;
            font-weight: 700;
            padding: .5rem 1.5rem;
            border-radius: 50px;
            margin-top: 1rem;
            font-size: .9rem;
        }

        /* ── FOOTER ── */
        footer {
            background: var(--noir);
            color: rgba(255,255,255,.6);
            text-align: center;
            padding: 2.5rem 6%;
        }
        .footer-logo { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 1.4rem; color: #fff; margin-bottom: .5rem; }
        .footer-logo em { color: var(--orange); font-style: normal; }
        .footer-links { display: flex; justify-content: center; flex-wrap: wrap; gap: .5rem 1.5rem; list-style: none; margin: 1rem 0; }
        .footer-links a { color: rgba(255,255,255,.6); text-decoration: none; font-size: .85rem; }
        .footer-links a:hover { color: var(--orange); }
        .footer-legal { font-size: .75rem; color: rgba(255,255,255,.35); margin-top: .75rem; line-height: 1.6; }
    
        /* === NAVIGATION === */
        nav{background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.07);padding:0 4%;height:70px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1000}
        .logo{font-size:1.45rem;font-weight:900;color:#1a1a2e;text-decoration:none;letter-spacing:-.03em}
        .logo span{color:#e67e22}
        .nav-links{display:flex;gap:.5rem 1rem;list-style:none;align-items:center;flex-wrap:wrap;justify-content:flex-end;margin:0;padding:0}
        .nav-links a{font-size:.78rem;font-weight:600;color:#555;text-transform:uppercase;letter-spacing:.04em;text-decoration:none;white-space:nowrap;padding:.3rem .4rem;transition:color .2s}
        .nav-links a:hover,.nav-links a.active{color:#e67e22}
        .nav-links .nav-yt{background:#e67e22;color:#fff!important;padding:.4rem 1rem;border-radius:30px;font-weight:700}
        .nav-links .nav-yt:hover{background:#cf6d17}
        .nav-links .nav-yt-icon{background:#ff0000;color:#fff!important;padding:.4rem .8rem;border-radius:6px;font-weight:700;font-size:.75rem}
        .has-drop{position:relative}
        .has-drop>a::after{content:' ▾';font-size:.65rem;opacity:.6}
        .dropdown{display:none;position:absolute;top:calc(100% + 6px);left:0;background:#fff;border:1px solid #e8e8e8;border-radius:10px;box-shadow:0 8px 28px rgba(0,0,0,.12);min-width:200px;padding:.5rem 0;z-index:9999}
        .dropdown a{display:block;padding:.52rem 1.1rem;font-size:.8rem;color:#1a1a2e!important;font-weight:500;white-space:nowrap;text-transform:none;letter-spacing:normal}
        .dropdown a:hover{background:#fff8f2;color:#e67e22!important}
        .nav-last-video{display:inline-flex;align-items:center;gap:.4rem;background:#fff3e0;border:1px solid #f0a500;border-radius:20px;padding:.3rem .8rem;font-size:.72rem!important;font-weight:700!important;color:#e67e22!important;text-transform:none!important;letter-spacing:normal!important;white-space:nowrap;animation:pulse-badge 2.5s infinite}
        @keyframes pulse-badge{0%,100%{box-shadow:0 0 0 0 rgba(230,126,34,.35)}50%{box-shadow:0 0 0 5px rgba(230,126,34,0)}}
        .nav-last-video .dot{width:7px;height:7px;background:#e74c3c;border-radius:50%;animation:blink 1.2s infinite}
        @keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
        .nav-last-video .label-new{font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em}
        .menu-toggle{display:none;font-size:1.8rem;cursor:pointer;background:none;border:none;color:#1a1a2e;padding:.5rem}
        @media(max-width:900px){
            .nav-links{display:none;flex-direction:column;position:absolute;top:70px;left:0;width:100%;background:#fff;padding:1rem 0;box-shadow:0 10px 20px rgba(0,0,0,.1);z-index:1000;gap:0;align-items:stretch}
            .nav-links.active{display:flex}
            .nav-links li{width:100%;text-align:center}
            .nav-links a{display:block;padding:1rem!important;font-size:.95rem}
            .has-drop>a::after{display:none}
            .dropdown{position:static;width:100%;box-shadow:none;border:none;border-top:1px solid #e8e8e8;border-radius:0;padding:0;background:#fafafa}
            .menu-toggle{display:block}
            .nav-links .nav-yt,.nav-links .nav-yt-icon{margin:.5rem auto;display:inline-block;width:auto}
            .desktop-only{display:none!important}
        }
        @media(min-width:901px){.mobile-only{display:none!important}}
        /* === FIN NAVIGATION === */
        </style>
</head>
<body>

<!-- ======================================== -->
<!-- NAVIGATION UNIQUE LCDMH (NE PAS MODIFIER) -->
<!-- ======================================== -->
<div id="lcdmh-nav-container"></div>
<script>
(function() {
    // Charger la navigation depuis nav.html (chemin relatif)
    fetch('nav.html?t=' + Date.now())
        .then(response => response.text())
        .then(html => {
            document.getElementById('lcdmh-nav-container').innerHTML = html;
            
            // Marquer la page active
            const page = window.location.pathname.split('/').pop() || 'index.html';
            document.querySelectorAll('#lcdmh-nav .nav-links > li > a').forEach(link => {
                const href = link.getAttribute('href') || '';
                if (href && href !== '#' && page.indexOf(href.replace('.html', '')) !== -1) {
                    link.classList.add('active');
                }
            });
        })
        .catch(err => {
            console.error('❌ Navigation non chargée:', err);
            // Fallback ultra minimal
            document.getElementById('lcdmh-nav-container').innerHTML = 
                '<nav style="background:#fff;padding:1rem;"><a href="index.html" style="color:#e67e22;font-weight:bold;font-size:1.5rem;">LCDMH</a></nav>';
        });
})();
</script>
