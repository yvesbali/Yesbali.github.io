<!-- Trip feed YouTube (s'active quand trips.json est configuré) -->
<script>const TRIP_SLUG = "ecosse-irlande-2025";</script>
<script src="js/trip-feed.js"></script>
<script>
    // Cache le bloc "coming soon" si des vidéos sont chargées
    window.addEventListener('load', function() {
        setTimeout(function() {
            const hasVideos = document.querySelector('#trip-videos .lc-section') ||
                              document.querySelector('#trip-shorts .lc-section');
            if (hasVideos) {
                const block = document.getElementById('coming-soon-block');
                if (block) block.style.display = 'none';
            }
        }, 2000);
    });
</script>

