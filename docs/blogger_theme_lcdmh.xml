<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
<meta content='width=device-width, initial-scale=1' name='viewport'/>
<b:include data='blog' name='all-head-content'/>
<title><data:blog.pageTitle/></title>
<style type='text/css'>
/* === LCDMH Blogger Theme === */
:root {
  --orange: #ff6b35;
  --orange-dark: #e55a2b;
  --bg: #0f0f0f;
  --bg2: #1a1a1a;
  --bg3: #242424;
  --card: #1e1e1e;
  --border: #333;
  --text: #f5f5f5;
  --text2: #a0a0a0;
  --text3: #666;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.7;
  font-size: 16px;
}

a { color: var(--orange); text-decoration: none; }
a:hover { text-decoration: underline; }

/* === HEADER === */
#header-wrapper {
  background: linear-gradient(135deg, #1a1a1a 0%, #0f0f0f 100%);
  border-bottom: 3px solid var(--orange);
  padding: 30px 20px;
  text-align: center;
}

#header-wrapper h1,
#header-wrapper .titlewrapper h1 {
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -1px;
  margin: 0;
}

#header-wrapper .descriptionwrapper p,
#header-wrapper p.description {
  color: var(--text2);
  font-size: 0.95rem;
  margin-top: 6px;
}

/* === NAV / TABS === */
.tabs-outer, .tabs-inner {
  background: var(--bg2) !important;
  border: none !important;
}

.PageList li a, .tabs-inner a {
  color: var(--text2) !important;
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 10px 16px !important;
}

.PageList li a:hover, .tabs-inner a:hover {
  color: var(--orange) !important;
}

/* === MAIN CONTENT === */
.content-outer, .content-inner,
.main-outer, .main-inner,
.column-center-outer, .column-center-inner {
  background: var(--bg) !important;
  border: none !important;
}

.blog-posts { max-width: 800px; margin: 0 auto; padding: 20px; }

/* === POST CARDS === */
.date-header span {
  color: var(--text3);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.post {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 24px;
  transition: transform 0.2s;
}

.post:hover {
  transform: translateY(-2px);
  border-color: var(--orange);
}

.post-title, .post h3 {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12px;
  line-height: 1.3;
}

.post-title a { color: var(--text); }
.post-title a:hover { color: var(--orange); text-decoration: none; }

.post-body {
  color: var(--text2);
  font-size: 0.95rem;
  line-height: 1.8;
}

.post-body img {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 16px 0;
}

.post-body a {
  color: var(--orange);
  font-weight: 600;
}

/* === CTA BUTTONS (from teaser) === */
.post-body div[style*="background:#fff3e6"] {
  border-radius: 12px !important;
  margin: 20px 0 !important;
}

/* === POST FOOTER === */
.post-footer {
  margin-top: 16px;
  padding-top: 12px;
  border-top: 1px solid var(--border);
  font-size: 0.82rem;
  color: var(--text3);
}

.post-footer a { color: var(--text3); }
.post-footer a:hover { color: var(--orange); }

/* === LABELS === */
.post-labels a,
.label-name {
  display: inline-block;
  background: rgba(255, 107, 53, 0.15);
  color: var(--orange);
  padding: 2px 10px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  margin: 2px 4px 2px 0;
}

/* === SIDEBAR === */
.sidebar-container, .sidebar,
.column-right-outer, .column-right-inner,
.column-left-outer, .column-left-inner {
  background: var(--bg) !important;
}

.sidebar .widget {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px;
  margin-bottom: 16px;
}

.sidebar .widget h2, .sidebar .widget h3 {
  color: var(--orange);
  font-size: 0.9rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid var(--border);
}

.sidebar .widget ul { list-style: none; padding: 0; }

.sidebar .widget li {
  padding: 6px 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.88rem;
}

.sidebar .widget li:last-child { border-bottom: none; }

.sidebar .widget li a { color: var(--text2); }
.sidebar .widget li a:hover { color: var(--orange); }

.sidebar .widget .profile-img,
.sidebar .widget img {
  border-radius: 50%;
  max-width: 80px;
}

/* === ARCHIVE === */
.archive-list { list-style: none; padding: 0; }

/* === COMMENTS === */
.comments {
  background: var(--card);
  border-radius: 12px;
  padding: 20px;
  margin-top: 20px;
}

.comments h4 {
  color: var(--orange);
  margin-bottom: 16px;
}

/* === FOOTER === */
.footer-outer {
  background: var(--bg2) !important;
  border-top: 1px solid var(--border);
  text-align: center;
  padding: 20px;
  color: var(--text3);
  font-size: 0.82rem;
}

.footer-outer a { color: var(--orange); }

/* === PAGINATION === */
.blog-pager {
  text-align: center;
  padding: 20px;
}

.blog-pager a {
  display: inline-block;
  background: var(--orange);
  color: white !important;
  padding: 10px 20px;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9rem;
  margin: 0 8px;
  text-decoration: none !important;
}

.blog-pager a:hover {
  background: var(--orange-dark);
}

/* === SEARCH === */
.search-input input {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 8px 12px;
  border-radius: 8px;
  width: 100%;
}

.search-action input {
  background: var(--orange);
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
}

/* === RESPONSIVE === */
@media (max-width: 768px) {
  #header-wrapper h1 { font-size: 1.6rem; }
  .post { padding: 16px; margin-bottom: 16px; }
  .post-title { font-size: 1.2rem; }
  .blog-posts { padding: 12px; }
}

/* === HIDE UGLY DEFAULT STUFF === */
.navbar, #navbar, .navbar-fixed-top { display: none !important; }
.content-outer { border: none !important; }
</style>
</head>
<body>
<b:skin><![CDATA[
/* Variable definitions - keep minimal */
]]></b:skin>

<!-- HEADER -->
<div id='header-wrapper'>
<b:section class='header' id='header' maxwidgets='1'>
<b:widget id='Header1' locked='true' title='LCDMH, La Chaîne Du Motard Heureux' type='Header' version='1'>
<b:includable id='main'>
<div>
<h1><data:title/></h1>
<p class='description'><data:description/></p>
</div>
</b:includable>
</b:widget>
</b:section>
</div>

<!-- NAV -->
<div class='tabs-outer'>
<b:section class='tabs' id='crosscol' maxwidgets='1' showaddelement='yes'>
<b:widget id='PageList1' locked='false' title='Pages' type='PageList' version='2'>
<b:includable id='main'>
<div class='widget-content'>
<b:if cond='data:title != &quot;&quot;'>
</b:if>
<ul>
<b:loop values='data:links' var='link'>
<li><a expr:href='data:link.href'><data:link.title/></a></li>
</b:loop>
</ul>
</div>
</b:includable>
</b:widget>
</b:section>
</div>

<!-- MAIN + SIDEBAR -->
<div class='content-outer'>
<div class='content-inner' style='max-width:1100px;margin:0 auto;display:flex;gap:24px;padding:24px'>

<!-- POSTS -->
<div class='main-outer' style='flex:1;min-width:0'>
<b:section class='main' id='main' showaddelement='no'>
<b:widget id='Blog1' locked='true' title='Articles du blog' type='Blog' version='1'>
<b:includable id='main' var='top'>
<b:if cond='data:blog.pageType == &quot;static_page&quot;'>
<b:include data='post' name='post'/>
<b:else/>
<b:loop values='data:posts' var='post'>
<b:include data='post' name='post'/>
</b:loop>
<b:include name='nextprev'/>
</b:if>
</b:includable>

<b:includable id='post' var='post'>
<div class='post'>
<b:if cond='data:post.dateHeader'>
<div class='date-header'><span><data:post.dateHeader/></span></div>
</b:if>
<h3 class='post-title'>
<b:if cond='data:post.link'>
<a expr:href='data:post.link'><data:post.title/></a>
<b:else/>
<b:if cond='data:post.url'>
<a expr:href='data:post.url'><data:post.title/></a>
<b:else/>
<data:post.title/>
</b:if>
</b:if>
</h3>
<div class='post-body'><data:post.body/></div>
<div class='post-footer'>
<b:if cond='data:post.labels'>
<span class='post-labels'>
<b:loop values='data:post.labels' var='label'>
<a class='label-name' expr:href='data:label.url'><data:label.name/></a>
</b:loop>
</span>
</b:if>
</div>
</div>
</b:includable>

<b:includable id='nextprev'>
<div class='blog-pager'>
<b:if cond='data:newerPageUrl'>
<a class='blog-pager-newer-link' expr:href='data:newerPageUrl'>Articles plus récents</a>
</b:if>
<b:if cond='data:olderPageUrl'>
<a class='blog-pager-older-link' expr:href='data:olderPageUrl'>Articles plus anciens</a>
</b:if>
</div>
</b:includable>

<b:includable id='status-message'/>
<b:includable id='comment-form'/>
<b:includable id='backlinkDeleteIcon'/>
<b:includable id='backlinks'/>
<b:includable id='feedLinks'/>
<b:includable id='feedLinksBody'/>
<b:includable id='postQuickEdit'/>
</b:widget>
</b:section>
</div>

<!-- SIDEBAR -->
<div class='sidebar' style='width:300px;flex-shrink:0'>
<b:section class='sidebar' id='sidebar-right-1' preferred='yes'>

<b:widget id='Profile1' locked='false' title='Qui suis-je ?' type='Profile' version='1'>
<b:includable id='main'>
<div class='widget-content'>
<h2>Qui suis-je ?</h2>
<p style='color:#a0a0a0;font-size:0.9rem'>Yves — Motard, vidéaste, aventurier. Je parcours l&#39;Europe à moto et je partage mes road trips, tests matériel et guides pratiques.</p>
<p style='margin-top:12px'><a href='https://lcdmh.com' style='background:#ff6b35;color:white;padding:8px 16px;border-radius:6px;font-weight:600;font-size:0.85rem;display:inline-block'>Visiter LCDMH.com</a></p>
<p style='margin-top:8px'><a href='https://www.youtube.com/@LCDMH?sub_confirmation=1' style='color:#ff6b35;font-size:0.85rem'>▶️ S&#39;abonner sur YouTube</a></p>
</div>
</b:includable>
</b:widget>

<b:widget id='Label1' locked='false' title='Catégories' type='Label' version='2'>
<b:includable id='main'>
<div class='widget-content'>
<h2>Catégories</h2>
<ul>
<b:loop values='data:labels' var='label'>
<li><a expr:href='data:label.url'><data:label.name/></a> (<data:label.count/>)</li>
</b:loop>
</ul>
</div>
</b:includable>
</b:widget>

<b:widget id='BlogArchive1' locked='false' title='Archives' type='BlogArchive' version='1'>
<b:includable id='main'>
<div class='widget-content'>
<h2>Archives</h2>
<div class='widget-content'>
<data:content/>
</div>
</div>
</b:includable>
</b:widget>

</b:section>
</div>

</div>
</div>

<!-- FOOTER -->
<div class='footer-outer'>
<p>🏍️ <a href='https://lcdmh.com'>LCDMH</a> — La Chaîne du Motard Heureux · Annecy, France</p>
<p style='margin-top:4px'><a href='https://www.youtube.com/@LCDMH'>YouTube</a> · <a href='https://lcdmh.com/articles.html'>Articles</a> · <a href='https://lcdmh.com/codes-promo.html'>Codes Promo</a></p>
</div>

</body>
</html>